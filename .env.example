# Copy to `.env` and adjust. Every var is optional — sane defaults live in config.py.
# The defaults run fully local (ollama + mistral-small:24b); no .env is needed to run the demo.
# All overrides use the PORTDOC_ prefix.

# --- LLM backend (slice 6). LiteLLM treats all three as OpenAI-compatible. ---
#   ollama -> local self-hosted model   (the sovereignty default — what config.py uses)
#   vllm   -> on-prem GPU server         (data-center / scale profile)
#   openai -> a cloud API                (fast dev, or the strong eval JUDGE)

# ollama profile (DEFAULT — no .env needed; Ollama uses the GPU automatically if present):
# PORTDOC_LLM_BACKEND=ollama
# PORTDOC_LLM_MODEL=mistral-small:24b
# PORTDOC_LLM_API_BASE=http://localhost:11434   # optional; this is already the default

# vllm profile (on-prem GPU; OpenAI-compatible endpoint):
# PORTDOC_LLM_BACKEND=vllm
# PORTDOC_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# PORTDOC_LLM_API_BASE=http://localhost:8001/v1   # note: the FastAPI app itself uses :8000

# openai / cloud profile (e.g. the eval judge — a model stronger than the one under test):
# PORTDOC_LLM_BACKEND=openai
# PORTDOC_LLM_MODEL=gpt-4o-mini
# PORTDOC_LLM_API_KEY=sk-...

# --- infra (slice 4+) ---
# PORTDOC_QDRANT_URL=http://localhost:6333
