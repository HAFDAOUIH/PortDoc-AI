# Copy to `.env` and adjust. Every var is optional — defaults live in config.py.
# All overrides use the PORTDOC_ prefix.

# --- LLM backend (slice 6). LiteLLM treats all three as OpenAI-compatible. ---
# vllm   -> local Ministral-3-14B (sovereignty profile, GPU)
# ollama -> local Ministral-3-8B q4_K_M (CPU profile)
# openai -> cloud, for fast iteration on days 1-4
PORTDOC_LLM_BACKEND=openai

# openai profile:
# PORTDOC_LLM_MODEL=gpt-4o-mini
# PORTDOC_LLM_API_KEY=sk-...

# ollama profile:
# PORTDOC_LLM_BACKEND=ollama
# PORTDOC_LLM_MODEL=ministral-3:8b-instruct-2512-q4_K_M
# PORTDOC_LLM_API_BASE=http://localhost:11434/v1

# vllm profile:
# PORTDOC_LLM_BACKEND=vllm
# PORTDOC_LLM_MODEL=mistralai/Ministral-3-14B-Instruct-2512
# PORTDOC_LLM_API_BASE=http://localhost:8000/v1

# --- infra (slice 4+) ---
# PORTDOC_QDRANT_URL=http://localhost:6333
