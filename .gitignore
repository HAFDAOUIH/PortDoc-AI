# fetched source documents — reproducible from the manifest, never committed
# (the processed data/corpus/chunks.jsonl IS committed so the repo runs without them)
data/corpus/raw/
*.part

# python
__pycache__/
*.pyc
.venv/
.pytest_cache/
*.egg-info/

# env / secrets
.env
*.env.local

# model weight cache
.cache/

# node / next (belt-and-suspenders; frontend/.gitignore also covers these)
node_modules/
frontend/.next/
frontend/out/
frontend/.env*.local

# logs
*.log

# private interview/demo notebook — NOT for a public repo
final.md

# editor local-history + screenshot scratch (rejected/oversized captures)
.history/
docs/img/_unused/
